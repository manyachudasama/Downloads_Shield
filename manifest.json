{
  "manifest_version": 3,
  "name": "Download Shield - Smart Download Protector",
  "version": "1.0.0",
  "description": "Blocks dangerous and suspicious file downloads",

  "permissions": [
    "downloads",
    "downloads.open",
    "storage",
    "tabs"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "src/background/serviceWorker.js",
    "type": "module"
  },

  "action": {
    "default_popup": "src/ui/popup.html",
    "default_icon": {
      "16": "icons/icon.jpg",
      "32": "icons/icon.jpg",
      "48": "icons/icon.jpg"
    }
  },

  "icons": {
    "16": "icons/icon.jpg",
    "32": "icons/icon.jpg",
    "48": "icons/icon.jpg",
    "128": "icons/icon.jpg"
  }
}